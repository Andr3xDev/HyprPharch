{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "kitty-direct",
        "source": "~/.config/fastfetch/images/abysal-marble.png",
        "width": 28,
        "height": 13,
        "padding": {
            "top": 2,
            "left": 3
        }
    },
